# Model
MODEL_NAME=microsoft/deberta-v3-base
CHECKPOINT_PATH=./model/checkpoints/best_model
NUM_LABELS=6
MAX_SEQ_LEN=512

# API
API_HOST=0.0.0.0
API_PORT=8000
CONFIDENCE_THRESHOLD=0.75

# Redis (rate limiting)
REDIS_URL=redis://localhost:6379
RATE_LIMIT_RPM=60

# Optional: HuggingFace Hub (to push model)
HF_TOKEN=your_hf_token_here
HF_REPO_ID=your-username/adversarialshield